{
  "name": "redux-astroglide",
  "version": "1.0.1",
  "description": "Taking the pain out of redux state management",
  "keywords": [
    "redux",
    "flux",
    "state",
    "typescript",
    "react"
  ],
  "homepage": "https://github.com/Mulletware/redux-astroglide.git",
  "bugs": {
    "url": "https://github.com/Mulletware/redux-astroglide.git/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mulletware/redux-astroglide.git"
  },
  "license": "MIT",
  "author": "Dustin Schultz <dmanke@gmail.com>",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./plugins": {
      "types": "./dist/types/plugins/index.d.ts",
      "import": "./dist/plugins/index.mjs",
      "require": "./dist/plugins/index.js"
    },
    "./plugins/set": {
      "types": "./dist/types/plugins/set/index.d.ts",
      "import": "./dist/plugins/set/index.mjs",
      "require": "./dist/plugins/set/index.js"
    },
    "./plugins/type": {
      "types": "./dist/types/plugins/type/index.d.ts",
      "import": "./dist/plugins/type/index.mjs",
      "require": "./dist/plugins/type/index.js"
    },
    "./plugins/persist": {
      "types": "./dist/types/plugins/persist/index.d.ts",
      "import": "./dist/plugins/persist/index.mjs",
      "require": "./dist/plugins/persist/index.js"
    },
    "./selectors": {
      "types": "./dist/types/selectors/index.d.ts",
      "import": "./dist/selectors/index.mjs",
      "require": "./dist/selectors/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "browser": "./dist/index.umd.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist",
    "plugins",
    "selectors"
  ],
  "scripts": {
    "start": "BUILD_ENV=dev npm run build:js -- --watch",
    "build": "rimraf dist && npm run build:js && npm run build:types",
    "build:js": "rollup -c",
    "build:types": "tsc --emitDeclarationOnly",
    "prepare": "husky install",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "sync:exports": "node scripts/sync-exports.js",
    "validate:exports": "node scripts/validate-exports.js",
    "test:exports": "node scripts/test-exports.js",
    "lint:package": "publint",
    "prepack": "npm run validate:exports && npm run lint:package",
    "prepublishOnly": "npm run build && npm run test:exports"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "check-prop-types": "^1.1.2",
    "lodash": "4.17.21",
    "redux-injectable-middleware": "^1.0.5"
  },
  "devDependencies": {
    "@babel/core": "^7.18.2",
    "@babel/preset-env": "^7.18.2",
    "@babel/preset-typescript": "^7.17.12",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "17.0.3",
    "@reduxjs/toolkit": "^1.9.2",
    "@rollup/plugin-babel": "5.3.1",
    "@rollup/plugin-commonjs": "^22.0.0",
    "@rollup/plugin-json": "^4.1.0",
    "@rollup/plugin-node-resolve": "^13.3.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.0",
    "@semantic-release/npm": "^13.0.0",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/lodash": "4.14.182",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@types/react-redux": "^7.1.34",
    "husky": "^8.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-localstorage-mock": "^2.4.26",
    "lint-staged": "^12.4.2",
    "prettier": "^2.6.2",
    "prop-types": "^15.8.1",
    "publint": "^0.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^8.1.3",
    "rimraf": "^3.0.2",
    "rollup": "^2.74.1",
    "rollup-plugin-terser": "^7.0.2",
    "semantic-release": "^25.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "^4.7.2"
  },
  "peerDependencies": {
    "@reduxjs/toolkit": ">=1",
    "prop-types": ">=12",
    "react": ">=16",
    "react-dom": ">=16",
    "react-redux": ">=7",
    "redux": ">=3"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.25.0"
}
